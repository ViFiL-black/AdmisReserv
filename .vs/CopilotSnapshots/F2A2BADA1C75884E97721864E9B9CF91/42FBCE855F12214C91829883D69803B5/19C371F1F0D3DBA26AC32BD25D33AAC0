<Page x:Class="Admissions_Reserve.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Admissions_Reserve"
      mc:Ignorable="d" 
      d:DesignHeight="600" 
      d:DesignWidth="900"
      Title="Добро пожаловать"
      Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Верхний баннер -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="40,50">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="👋 Добро пожаловать!" 
                           FontSize="{StaticResource FontSizeXLarge}" 
                           FontWeight="Bold" 
                           Foreground="White"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Резервное приложение для приемной комиссии" 
                           FontSize="{StaticResource FontSizeLarge}" 
                           Foreground="#E0E0E0"/>
            </StackPanel>
        </Border>
        
        <!-- Основной контент -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,50">
                <!-- Карточка 1: Вход -->
                <Border Background="White" CornerRadius="8" Margin="0,0,20,0" Width="200" Padding="20">
                    <Border.Effect>
                        <DropShadow BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔑" FontSize="48" TextAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Вход в систему" 
                                   FontSize="{StaticResource FontSizeLarge}" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Авторизация пользователя" 
                                   FontSize="{StaticResource FontSizeSmall}" 
                                   Foreground="#666666"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>
                        <Button x:Name="BtnLogin" 
                                Content="Войти" 
                                Style="{StaticResource ModernButtonStyle}"
                                Height="40"
                                Click="BtnLogin_Click"
                                FontSize="{StaticResource FontSizeNormal}"/>
                    </StackPanel>
                </Border>
                
                <!-- Карточка 2: Поиск -->
                <Border Background="White" CornerRadius="8" Margin="0,0,20,0" Width="200" Padding="20">
                    <Border.Effect>
                        <DropShadow BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="48" TextAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Поиск данных" 
                                   FontSize="{StaticResource FontSizeLarge}" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Поиск абитуриентов" 
                                   FontSize="{StaticResource FontSizeSmall}" 
                                   Foreground="#666666"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>
                        <Button x:Name="BtnSearch" 
                                Content="Поиск" 
                                Style="{StaticResource ModernButtonStyle}"
                                Height="40"
                                Click="BtnSearch_Click"
                                FontSize="{StaticResource FontSizeNormal}"/>
                    </StackPanel>
                </Border>
                
                <!-- Карточка 3: Выход -->
                <Border Background="White" CornerRadius="8" Width="200" Padding="20">
                    <Border.Effect>
                        <DropShadow BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🚪" FontSize="48" TextAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="Выход" 
                                   FontSize="{StaticResource FontSizeLarge}" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Закрыть приложение" 
                                   FontSize="{StaticResource FontSizeSmall}" 
                                   Foreground="#666666"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>
                        <Button x:Name="BtnExit" 
                                Content="Выход" 
                                Style="{StaticResource ModernButtonStyle}"
                                Height="40"
                                Click="BtnExit_Click"
                                Background="#C50F1F"
                                FontSize="{StaticResource FontSizeNormal}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
