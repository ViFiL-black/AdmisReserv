<Page x:Class="Admissions_Reserve.View.ApplicantWizardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:Admissions_Reserve.View"
      Title="Мастер добавления абитуриента"
      Background="{StaticResource BackgroundBrush}">
    <DockPanel>
        <!-- Навигационная панель шагов -->
        <Border DockPanel.Dock="Top" 
                Background="White" 
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,15">
            <StackPanel>
                <TextBlock Text="📋 Этапы заполнения заявления" 
                           FontSize="{StaticResource FontSizeLarge}"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,15"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Margin="0">
                        <Button Content="1. Личность" 
                                Click="Step_Click" 
                                Tag="IdentityPage" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,8"
                                FontSize="{StaticResource FontSizeSmall}"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="→" Margin="4,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="2. Контакты" 
                                Click="Step_Click" 
                                Tag="ContactsPage" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,8"
                                FontSize="{StaticResource FontSizeSmall}"
                                Margin="8,0"/>
                        <TextBlock Text="→" Margin="4,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="3. Образование" 
                                Click="Step_Click" 
                                Tag="ApplicationTypeAndEducationPage" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,8"
                                FontSize="{StaticResource FontSizeSmall}"
                                Margin="8,0"/>
                        <TextBlock Text="→" Margin="4,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="4. Документы" 
                                Click="Step_Click" 
                                Tag="DocumentsPage" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,8"
                                FontSize="{StaticResource FontSizeSmall}"
                                Margin="8,0"/>
                        <TextBlock Text="→" Margin="4,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="5. Родственники" 
                                Click="Step_Click" 
                                Tag="RelativesPage" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,8"
                                FontSize="{StaticResource FontSizeSmall}"
                                Margin="8,0"/>
                        <TextBlock Text="→" Margin="4,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="6. Информация" 
                                Click="Step_Click" 
                                Tag="AdditionalInfoPage" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,8"
                                FontSize="{StaticResource FontSizeSmall}"
                                Margin="8,0"/>
                        <TextBlock Text="→" Margin="4,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="7. Конкурсы" 
                                Click="Step_Click" 
                                Tag="ApplicationCompetitionsPage" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,8"
                                FontSize="{StaticResource FontSizeSmall}"
                                Margin="8,0"/>
                        <TextBlock Text="→" Margin="4,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="8. Достижения" 
                                Click="Step_Click" 
                                Tag="IndividualAchievementsPage" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,8"
                                FontSize="{StaticResource FontSizeSmall}"
                                Margin="8,0"/>
                        <TextBlock Text="→" Margin="4,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="9. Приоритеты" 
                                Click="Step_Click" 
                                Tag="PrioritiesPage" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,8"
                                FontSize="{StaticResource FontSizeSmall}"
                                Margin="8,0"/>
                        <TextBlock Text="→" Margin="4,0" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                        <Button Content="10. Документы" 
                                Click="Step_Click" 
                                Tag="AttachedDocumentsPage" 
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="12,8"
                                FontSize="{StaticResource FontSizeSmall}"
                                Margin="8,0"/>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>
        
        <!-- Основной контент страницы -->
        <Frame x:Name="StepFrame" 
               NavigationUIVisibility="Hidden"
               Margin="20"/>
    </DockPanel>
</Page>
