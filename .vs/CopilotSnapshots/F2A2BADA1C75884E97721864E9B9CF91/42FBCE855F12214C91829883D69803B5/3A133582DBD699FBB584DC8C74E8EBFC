<Window x:Class="Admissions_Reserve.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" 
        Height="450" 
        Width="450" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        Style="{StaticResource ModernWindowStyle}"
        Icon="pack://application:,,,/Resources/app-icon.ico"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Левая часть с градиентом -->
        <Grid Grid.Row="0" Grid.RowSpan="2">
            <Rectangle Fill="{StaticResource PrimaryBrush}"/>
        </Grid>
        
        <!-- Форма входа -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
            <!-- Иконка и заголовок -->
            <TextBlock Text="🔐" FontSize="48" TextAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Вход в систему" 
                       FontSize="{StaticResource FontSizeXLarge}" 
                       FontWeight="Bold" 
                       Foreground="White"
                       TextAlignment="Center"
                       Margin="0,0,0,10"/>
            <TextBlock Text="Приемная комиссия" 
                       FontSize="{StaticResource FontSizeNormal}" 
                       Foreground="#E0E0E0"
                       TextAlignment="Center"
                       Margin="0,0,0,30"/>
            
            <!-- Поле логина -->
            <TextBlock Text="Логин" 
                       Style="{StaticResource ModernLabelStyle}"
                       Foreground="White"
                       Margin="0,0,0,8"/>
            <TextBox x:Name="txtUser" 
                     Style="{StaticResource ModernTextBoxStyle}"
                     Height="40"
                     Margin="0,0,0,20"
                     Padding="12,10"/>
            
            <!-- Поле пароля -->
            <TextBlock Text="Пароль" 
                       Style="{StaticResource ModernLabelStyle}"
                       Foreground="White"
                       Margin="0,0,0,8"/>
            <PasswordBox x:Name="txtPassword" 
                         Style="{StaticResource ModernTextBoxStyle}"
                         Height="40"
                         Margin="0,0,0,30"
                         Padding="12,10"/>
            
            <!-- Кнопки действия -->
            <Button Content="Войти" 
                    Style="{StaticResource ModernButtonStyle}"
                    Height="44"
                    Margin="0,0,0,10"
                    Click="BtnOk_Click"
                    Background="#00A4EF"
                    FontSize="{StaticResource FontSizeLarge}"
                    Cursor="Hand"/>
            <Button Content="Отмена" 
                    Height="44"
                    Margin="0"
                    Click="BtnCancel_Click"
                    Foreground="{StaticResource TextBrush}"
                    Background="White"
                    FontSize="{StaticResource FontSizeNormal}"
                    Cursor="Hand"
                    BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
