<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="Admissions_Reserve.View.RelativesPage"
    Title="Данные родственников">

	<Grid>
		<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<StackPanel Margin="15">

				<!-- ========== ЗАГОЛОВОК ========== -->
				<TextBlock Text="Данные родственников" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

				<!-- ========== ФОРМА ДОБАВЛЕНИЯ РОДСТВЕННИКА ========== -->
				<Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="12" Margin="0,0,0,15" Background="#FAFAFA">
					<StackPanel>
						<TextBlock Text="Добавление родственника" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

						<!-- Строка 1: Степень родства -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Степень родства" FontSize="11" VerticalAlignment="Center"/>
							<ComboBox Grid.Column="1" Name="RelationDegreeCombo" Height="23" FontSize="11" Margin="0,0,10,0" SelectedIndex="0">
								<ComboBoxItem Content="Отец"/>
								<ComboBoxItem Content="Мать"/>
								<ComboBoxItem Content="Брат"/>
								<ComboBoxItem Content="Сестра"/>
								<ComboBoxItem Content="Супруг"/>
								<ComboBoxItem Content="Супруга"/>
								<ComboBoxItem Content="Сын"/>
								<ComboBoxItem Content="Дочь"/>
								<ComboBoxItem Content="Дедушка"/>
								<ComboBoxItem Content="Бабушка"/>
								<ComboBoxItem Content="Опекун"/>
								<ComboBoxItem Content="Попечитель"/>
							</ComboBox>
							<TextBlock Grid.Column="2" Text="Фамилия*" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="3" Name="LastNameTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
							<TextBlock Grid.Column="4" Text="Имя*" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="5" Name="FirstNameTextBox" Height="23" FontSize="11"/>
						</Grid>

						<!-- Строка 2: Отчество + Тип удостоверения -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Отчество" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="PatronymicTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
							<TextBlock Grid.Column="2" Text="Тип удостоверения*" FontSize="11" VerticalAlignment="Center"/>
							<ComboBox Grid.Column="3" Name="IdTypeCombo" Height="23" FontSize="11" SelectedIndex="0">
								<ComboBoxItem Content="Паспорт РФ"/>
								<ComboBoxItem Content="Свидетельство о рождении"/>
								<ComboBoxItem Content="Загранпаспорт"/>
								<ComboBoxItem Content="Военный билет"/>
								<ComboBoxItem Content="Водительское удостоверение"/>
							</ComboBox>
						</Grid>

						<!-- Строка 3: Номер + Рождение (дата выдачи) -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Номер" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="IdNumberTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
							<TextBlock Grid.Column="2" Text="Дата выдачи" FontSize="11" VerticalAlignment="Center"/>
							<DatePicker Grid.Column="3" Name="IssueDatePicker" Height="23" FontSize="11"/>
						</Grid>

						<!-- Строка 4: Кем выдано + Код подразделения -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Кем выдано" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="IssuedByTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
							<TextBlock Grid.Column="2" Text="Код подразделения" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="3" Name="DepartmentCodeTextBox" Height="23" FontSize="11"/>
						</Grid>

						<!-- Строка 5: Дата рождения + Место рождения -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Дата рождения" FontSize="11" VerticalAlignment="Center"/>
							<DatePicker Grid.Column="1" Name="BirthDatePicker" Height="23" FontSize="11" Margin="0,0,10,0"/>
							<TextBlock Grid.Column="2" Text="Место рождения" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="3" Name="BirthPlaceTextBox" Height="23" FontSize="11"/>
						</Grid>

						<!-- Разделитель -->
						<TextBlock Text="Контактные данные" FontSize="12" FontWeight="SemiBold" Margin="0,10,0,8" Background="#E8EFF7" Padding="5"/>

						<!-- Строка 6: Телефон + Email -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Телефон" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="PhoneTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
							<TextBlock Grid.Column="2" Text="E-mail" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="3" Name="EmailTextBox" Height="23" FontSize="11"/>
						</Grid>

						<!-- Разделитель -->
						<TextBlock Text="Дополнительные данные" FontSize="12" FontWeight="SemiBold" Margin="0,10,0,8" Background="#E8EFF7" Padding="5"/>

						<!-- Строка 7: ОКПО + Правда/Дефакт -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="100"/>
								<ColumnDefinition Width="100"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="ОКПО (рег. код)" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="OkpoTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
							<CheckBox Grid.Column="2" Name="PravdaCheckBox" Content="Правда" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>
							<CheckBox Grid.Column="3" Name="DefactCheckBox" Content="Дефакт" FontSize="11" VerticalAlignment="Center"/>
						</Grid>

						<!-- Строка 8: ИНН -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="ИНН" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="InnTextBox" Height="23" FontSize="11"/>
						</Grid>

						<!-- Строка 9: Место работы + Должность -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Место работы" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="WorkPlaceTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
							<TextBlock Grid.Column="2" Text="Должность" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="3" Name="PositionTextBox" Height="23" FontSize="11"/>
						</Grid>

						<!-- Строка 10: Наименование банка получателя -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Наименование банка" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="BankNameTextBox" Height="23" FontSize="11"/>
						</Grid>

						<!-- Строка 11: Лицевой счет получателя -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Лицевой счет" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="PersonalAccountTextBox" Height="23" FontSize="11"/>
						</Grid>

						<!-- Разделитель -->
						<TextBlock Text="Адрес" FontSize="12" FontWeight="SemiBold" Margin="0,10,0,8" Background="#E8EFF7" Padding="5"/>

						<!-- Строка 12: Страна + Адрес ФИАС -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Страна*" FontSize="11" VerticalAlignment="Center"/>
							<ComboBox Grid.Column="1" Name="CountryCombo" Height="23" FontSize="11" Margin="0,0,10,0" SelectedIndex="0">
								<ComboBoxItem Content="Россия"/>
								<ComboBoxItem Content="Беларусь"/>
								<ComboBoxItem Content="Казахстан"/>
								<ComboBoxItem Content="Украина"/>
								<ComboBoxItem Content="Другая"/>
							</ComboBox>
							<TextBlock Grid.Column="2" Text="Адрес ФИАС" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="3" Name="FiasAddressTextBox" Height="23" FontSize="11" ToolTip="федеральный, местный"/>
						</Grid>

						<!-- Строка 13: Квартира -->
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Квартира" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="CabinetTextBox" Height="23" FontSize="11"/>
						</Grid>

						<!-- Кнопки формы -->
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
							<Button Name="AddToListButton" Content="Добавить в список" Width="150" Height="30"
                                    Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White" Click="AddRelativeButton_Click"/>
							<Button Name="CancelAddButton" Content="Отменить" Width="90" Height="30" FontSize="11"
                                    Background="#F0F0F0" Click="CancelAddButton_Click"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- ========== ТАБЛИЦА "РОДСТВЕННИКИ" ========== -->
				<TextBlock Text="Родственники" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

				<Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15">
					<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="200">
						<DataGrid Name="RegularRelativesGrid" AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="True"
                                  HeadersVisibility="Column" FontSize="11" BorderThickness="0"
                                  RowHeaderWidth="0">
							<DataGrid.Columns>
								<DataGridTextColumn Header="№" Width="40" Binding="{Binding Number}" />
								<DataGridTextColumn Header="ИНН" Width="120" Binding="{Binding Inn}" />
								<DataGridTextColumn Header="Степень родства" Width="110" Binding="{Binding RelationDegree}" />
								<DataGridTextColumn Header="Фамилия" Width="120" Binding="{Binding LastName}" />
								<DataGridTextColumn Header="Имя" Width="100" Binding="{Binding FirstName}" />
								<DataGridTextColumn Header="Отчество" Width="100" Binding="{Binding Patronymic}" />
								<DataGridTextColumn Header="Дата рождения" Width="100" Binding="{Binding BirthDate, StringFormat='dd.MM.yyyy'}" />
								<DataGridTextColumn Header="Телефон" Width="110" Binding="{Binding Phone}" />
								<DataGridTextColumn Header="Место работы" Width="150" Binding="{Binding WorkPlace}" />
								<DataGridTextColumn Header="Должность" Width="120" Binding="{Binding Position}" />
								<DataGridTemplateColumn Header="Удалить" Width="50">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<Button Content="X" FontSize="10" Width="25" Height="20"
                                                    Click="DeleteRegularRelative_Click" Tag="{Binding}"/>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
							</DataGrid.Columns>
						</DataGrid>
					</ScrollViewer>
				</Border>

				<!-- ========== ТАБЛИЦА "БЛОКИРОВКА РОДСТВЕННИКА" ========== -->
				<TextBlock Text="Блокировка Родственника" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

				<Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15">
					<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="200">
						<DataGrid Name="BlockedRelativesGrid" AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="True"
                                  HeadersVisibility="Column" FontSize="11" BorderThickness="0"
                                  RowHeaderWidth="0">
							<DataGrid.Columns>
								<DataGridTextColumn Header="№" Width="40" Binding="{Binding Number}" />
								<DataGridTextColumn Header="ИНН" Width="120" Binding="{Binding Inn}" />
								<DataGridTextColumn Header="Степень родства" Width="110" Binding="{Binding RelationDegree}" />
								<DataGridTextColumn Header="Фамилия" Width="120" Binding="{Binding LastName}" />
								<DataGridTextColumn Header="Имя" Width="100" Binding="{Binding FirstName}" />
								<DataGridTextColumn Header="Отчество" Width="100" Binding="{Binding Patronymic}" />
								<DataGridTextColumn Header="Дата рождения" Width="100" Binding="{Binding BirthDate, StringFormat='dd.MM.yyyy'}" />
								<DataGridTextColumn Header="Телефон" Width="110" Binding="{Binding Phone}" />
								<DataGridTextColumn Header="Место работы" Width="150" Binding="{Binding WorkPlace}" />
								<DataGridTextColumn Header="Должность" Width="120" Binding="{Binding Position}" />
								<DataGridTextColumn Header="Причина блокировки" Width="150" Binding="{Binding BlockReason}" />
								<DataGridTemplateColumn Header="Разблокировать" Width="80">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<Button Content="Разблок." FontSize="10" Width="65" Height="20"
                                                    Click="UnblockRelative_Click" Tag="{Binding}"/>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
							</DataGrid.Columns>
						</DataGrid>
					</ScrollViewer>
				</Border>

				<!-- Кнопка блокировки выбранного родственника -->
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
					<Button Name="BlockSelectedButton" Content="Блокировать выбранного" Width="160" Height="30"
                            FontSize="11" Background="#FF5722" Foreground="White" Click="BlockSelectedButton_Click"/>
				</StackPanel>

				<!-- ========== КНОПКИ НАВИГАЦИИ ========== -->
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
					<Button x:Name="PrevButton" Content="Назад" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#F0F0F0"/>
					<Button x:Name="NextButton" Content="Далее" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White"/>
					<Button x:Name="SaveButton" Content="Сохранить" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#4CAF50" Foreground="White"/>
					<Button x:Name="CancelButton" Content="Отменить" Width="90" Height="32" FontSize="11" Background="#F0F0F0"/>
				</StackPanel>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</Page>