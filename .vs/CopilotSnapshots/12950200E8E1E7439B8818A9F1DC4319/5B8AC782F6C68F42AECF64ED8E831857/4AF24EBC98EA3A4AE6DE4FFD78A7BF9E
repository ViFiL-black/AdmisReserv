<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      mc:Ignorable="d" 
      x:Class="Admissions_Reserve.View.ContactsPage"
      Title="Контакты">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Style="{StaticResource MainPanelStyle}" Margin="15">

                <!-- Контактные данные -->
                <TextBlock Text="Контактные данные" Style="{StaticResource SectionTitleStyle}" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Контактный телефон" FontSize="11"/>
                        <TextBox Height="23" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Рабочий телефон" FontSize="11"/>
                        <TextBox Height="23" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <TextBlock Text="Мобильный телефон" FontSize="11"/>
                        <TextBox Height="23" FontSize="11"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="E-mail" FontSize="11"/>
                        <TextBox Height="23" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Фактический адрес -->
                <TextBlock Text="Фактический адрес" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
                
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Страна " FontSize="11"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <ComboBox Height="23" FontSize="11">
                            <ComboBoxItem Content="Российская Федерация"/>
                            <ComboBoxItem Content="Беларусь"/>
                            <ComboBoxItem Content="Казахстан"/>
                            <ComboBoxItem Content="Украина"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Адрес ФИАС" FontSize="11"/>
                    <TextBox Height="23" FontSize="11"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Квартира" FontSize="11"/>
                    <TextBox Height="23" FontSize="11"/>
                </StackPanel>

                <!-- Кнопки навигации -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="PrevButton" Content="Назад" Width="90" Height="32" Margin="0,0,10,0" FontSize="11"/>
                    <Button x:Name="NextButton" Content="Далее" Width="90" Height="32" Margin="0,0,10,0" FontSize="11"/>
                    <Button x:Name="CancelButton" Content="Отменить" Width="90" Height="32" FontSize="11"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>