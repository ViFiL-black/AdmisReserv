<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    mc:Ignorable="d" 
    x:Class="Admissions_Reserve.View.DocumentsPage"
    Title="Документы">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Style="{StaticResource MainPanelStyle}" Margin="15">

                <!-- ========== ЗАГОЛОВОК ========== -->
                <TextBlock Text="Документы абитуриента" Style="{StaticResource PageTitleStyle}" />

                <!-- ========== ФОРМА ДОБАВЛЕНИЯ ДОКУМЕНТА ========== -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="12" Margin="0,0,0,15" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Добавление документа" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                        <!-- Первая строка: Вид документа -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вид документа:" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton Name="IdentityDocRadio" Content="Документ, удостоверяющий личность" 
                                             Margin="0,0,15,0" FontSize="11" IsChecked="True"/>
                                <RadioButton Name="OtherDocRadio" Content="Другой документ персональных данных" 
                                             FontSize="11"/>
                            </StackPanel>
                        </Grid>

                        <!-- Вторая строка: Данные документа -->
                        <TextBlock Text="Данные документа" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Тип документа*" FontSize="11" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" Name="DocumentTypeCombo" Height="23" FontSize="11" Margin="0,0,10,0" IsEditable="True">
                                <ComboBoxItem Content="Паспорт гражданина РФ"/>
                                <ComboBoxItem Content="Загранпаспорт"/>
                                <ComboBoxItem Content="Свидетельство о рождении"/>
                                <ComboBoxItem Content="Военный билет"/>
                                <ComboBoxItem Content="Водительское удостоверение"/>
                                <ComboBoxItem Content="Медицинская справка 086у"/>
                                <ComboBoxItem Content="Полис СМС"/>
                                <ComboBoxItem Content="Страховой номер индивидуального лицевого счета"/>
                                <ComboBoxItem Content="Фото 3x4"/>
                                <ComboBoxItem Content="Признанный сертификат"/>
                            </ComboBox>
                            <TextBlock Grid.Column="2" Text="Категория" FontSize="11" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="3" Name="CategoryCombo" Height="23" FontSize="11" SelectedIndex="0">
                                <ComboBoxItem Content="Абитуриент (прием П_К_2022/2023)"/>
                                <ComboBoxItem Content="Студент"/>
                                <ComboBoxItem Content="Сотрудник"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Серия" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Name="SeriesTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Номер" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="3" Name="NumberTextBox" Height="23" FontSize="11"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Дата выдачи" FontSize="11" VerticalAlignment="Center"/>
                            <DatePicker Grid.Column="1" Name="IssueDatePicker" Height="23" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Кем выдан" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="3" Name="IssuedByTextBox" Height="23" FontSize="11"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Доп. данные" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Name="AdditionalDataTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Информация о документе" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="3" Name="DocumentInfoTextBox" Height="23" FontSize="11"/>
                        </Grid>

                        <!-- Кнопки формы -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Name="AddToListButton" Content="Добавить в список документов" Width="180" Height="30" 
                                    Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White" Click="AddDocumentButton_Click"/>
                            <Button Name="CancelAddButton" Content="Отменить" Width="90" Height="30" FontSize="11" 
                                    Background="#F0F0F0" Click="CancelAddButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ========== ТАБЛИЦА ДОКУМЕНТОВ ========== -->
                <TextBlock Text="Список документов" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="250">
                        <DataGrid Name="DocumentsGrid" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" CanUserDeleteRows="True" 
                                  HeadersVisibility="Column" FontSize="11" BorderThickness="0"
                                  RowHeaderWidth="0" IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Тип документа" Width="150" Binding="{Binding DocumentType}" />
                                <DataGridTextColumn Header="Серия и номер" Width="120" Binding="{Binding SeriesNumber}" />
                                <DataGridTextColumn Header="Категория" Width="180" Binding="{Binding Category}" />
                                <DataGridTextColumn Header="Доп. данные" Width="150" Binding="{Binding AdditionalData}" />
                                <DataGridTextColumn Header="Дата выдачи" Width="100" Binding="{Binding IssueDate, StringFormat='dd.MM.yyyy'}" />
                                <DataGridTextColumn Header="Информация о документе" Width="200" Binding="{Binding DocumentInfo}" />
                                <DataGridTextColumn Header="Дата добавления" Width="140" Binding="{Binding AddedDate, StringFormat='dd.MM.yyyy HH:mm'}" />
                                <DataGridTextColumn Header="Категория персональных данных" Width="200" Binding="{Binding PersonalDataCategory}" />
                                <DataGridTemplateColumn Header="Удалить" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="X" FontSize="10" Width="25" Height="20" 
                                                    Click="DeleteDocument_Click" Tag="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>

                <!-- ========== ДОКУМЕНТЫ ПЕРСОНАЛЬНЫХ ДАННЫХ ========== -->
                <TextBlock Text="Документы персональных данных" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                        <DataGrid Name="PersonalDataDocumentsGrid" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" CanUserDeleteRows="False" 
                                  HeadersVisibility="Column" FontSize="11" BorderThickness="0"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Тип документа" Width="150" Binding="{Binding DocumentType}" />
                                <DataGridTextColumn Header="Серия и номер" Width="120" Binding="{Binding SeriesNumber}" />
                                <DataGridTextColumn Header="Категория" Width="180" Binding="{Binding Category}" />
                                <DataGridTextColumn Header="Доп. данные" Width="150" Binding="{Binding AdditionalData}" />
                                <DataGridTextColumn Header="Дата выдачи" Width="100" Binding="{Binding IssueDate, StringFormat='dd.MM.yyyy'}" />
                                <DataGridTextColumn Header="Информация о документе" Width="250" Binding="{Binding DocumentInfo}" />
                                <DataGridTextColumn Header="Дата добавления" Width="140" Binding="{Binding AddedDate, StringFormat='dd.MM.yyyy HH:mm'}" />
                                <DataGridTextColumn Header="Категория персональных данных" Width="200" Binding="{Binding PersonalDataCategory}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>

                <!-- ========== КНОПКИ НАВИГАЦИИ ========== -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
                    <Button x:Name="PrevButton" Content="Назад" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#F0F0F0"/>
                    <Button x:Name="NextButton" Content="Далее" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White"/>
                    <Button x:Name="SaveButton" Content="Сохранить" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#4CAF50" Foreground="White"/>
                    <Button x:Name="CancelButton" Content="Отменить" Width="90" Height="32" FontSize="11" Background="#F0F0F0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>