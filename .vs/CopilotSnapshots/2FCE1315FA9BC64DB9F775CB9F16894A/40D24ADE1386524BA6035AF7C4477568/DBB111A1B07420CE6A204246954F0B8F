<Page x:Class="Admissions_Reserve.View.IdentityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Удостоверение личности">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="15" MaxWidth="1000">
                <!-- Выбор удостоверения личности -->
                <TextBlock Text="Выбор удостоверения личности" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
                <StackPanel Margin="0,0,0,12">
                    <RadioButton Name="ExistingIdentityRadio" Content="▼" Margin="0,0,0,5" FontSize="10"/>
                    <RadioButton Content="Новое удостоверение личности" Margin="0,0,0,5" FontSize="10"/>
                </StackPanel>

                <!-- ФИО -->
                <TextBlock Text="ФИО" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Фамилия " FontSize="10"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBox Height="23" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Имя " FontSize="10"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBox Height="23" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Отчество" FontSize="10"/>
                        <TextBox Height="23" FontSize="10"/>
                    </StackPanel>
                </Grid>

                <!-- Пол -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Пол" FontSize="10"/>
                        <ComboBox Height="23" FontSize="10">
                            <ComboBoxItem>Мужской</ComboBoxItem>
                            <ComboBoxItem>Женский</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Удостоверение личности -->
                <TextBlock Text="Удостоверение личности" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Тип удостоверения" FontSize="10"/>
                        <ComboBox Height="23" FontSize="10">
                            <ComboBoxItem>Паспорт</ComboBoxItem>
                            <ComboBoxItem>Свидетельство о рождении</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Серия " FontSize="10"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBox Height="23" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Номер " FontSize="10"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBox Height="23" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Гражданство " FontSize="10"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <ComboBox Height="23" FontSize="10">
                            <ComboBoxItem>Российская Федерация</ComboBoxItem>
                            <ComboBoxItem>Беларусь</ComboBoxItem>
                            <ComboBoxItem>Казахстан</ComboBoxItem>
                            <ComboBoxItem>Украина</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Кем выдано удостоверение" FontSize="10"/>
                        <TextBox Height="23" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Код подразделения" FontSize="10"/>
                        <TextBox Height="23" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Дата выдачи " FontSize="10"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <DatePicker Height="23" FontSize="10"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Дата рождения " FontSize="10"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <DatePicker Height="23" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Место рождения" FontSize="10"/>
                        <TextBox Height="23" FontSize="10"/>
                    </StackPanel>
                </Grid>

                <!-- СНИЛС -->
                <TextBlock Text="СНИЛС" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="СНИЛС (третий символ с конца) " FontSize="10"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBox Height="23" FontSize="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="СНИЛС" FontSize="10"/>
                        <TextBox Height="23" FontSize="10"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,12">
                    <RadioButton Content="Пробел" Margin="0,0,0,3" FontSize="10"/>
                    <RadioButton Content="Дефис" Margin="0,0,0,3" FontSize="10"/>
                </StackPanel>

                <!-- Адрес регистрации -->
                <TextBlock Text="Адрес регистрации" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Страна " FontSize="10"/>
                            <TextBlock Text="*" Foreground="Red" FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <ComboBox Height="23" FontSize="10">
                            <ComboBoxItem>Российская Федерация</ComboBoxItem>
                            <ComboBoxItem>Беларусь</ComboBoxItem>
                            <ComboBoxItem>Казахстан</ComboBoxItem>
                            <ComboBoxItem>Украина</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Адрес ФИАС" FontSize="10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Height="23" FontSize="10"/>
                        <Button Grid.Column="1" Content="Проверить" Width="100" Height="23" Margin="5,0,0,0" FontSize="10"/>
                    </Grid>
                </StackPanel>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Квартира" FontSize="10"/>
                    <TextBox Height="23" FontSize="10"/>
                </StackPanel>

                <CheckBox Content="Адрес регистрации совпадает с фактическим адресом" Margin="0,0,0,15" FontSize="10"/>

                <!-- Кнопки навигации -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Name="PrevButton" Content="Назад" Width="90" Height="32" Margin="0,0,10,0" FontSize="10"/>
                    <Button Name="NextButton" Content="Далее" Width="90" Height="32" Margin="0,0,10,0" FontSize="10"/>
                    <Button Name="CancelButton" Content="Отменить" Width="90" Height="32" FontSize="10"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>