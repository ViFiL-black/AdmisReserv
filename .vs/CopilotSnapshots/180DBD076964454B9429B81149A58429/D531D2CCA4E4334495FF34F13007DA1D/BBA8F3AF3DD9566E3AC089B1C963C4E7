        private static void EnsureApplicantColumnsExist(SQLiteConnection connection)
        {
            var requiredColumns = new Dictionary<string, string>
            {
                { "Inn", "TEXT" }, { "BirthCountryId", "INTEGER" },
                { "NeedsDormitory", "INTEGER DEFAULT 0" }, { "HasDormitoryBenefits", "INTEGER DEFAULT 0" },
                { "HasSportsAchievements", "INTEGER DEFAULT 0" },
                { "CompletedPreparatoryCourses", "INTEGER DEFAULT 0" }, { "CompletedPreparatoryDepartment", "INTEGER DEFAULT 0" },
                { "CompletedMedicalEducation", "INTEGER DEFAULT 0" }, { "CurrentWorkPlace", "TEXT" },
                { "ServedInArmy", "INTEGER DEFAULT 0" },
                { "ServiceStartDate", "TEXT" }, { "ServiceEndDate", "TEXT" },
                { "ReserveYear", "INTEGER" }, { "ApplicationComment", "TEXT" }
            };

            var existing = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            try
            {
                using (var cmd = new SQLiteCommand("PRAGMA table_info(Applicants);", connection))
                using (var reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                        existing.Add(reader[1].ToString());
                }
            }
            catch { return; }

            foreach (var kv in requiredColumns)
            {
                if (!existing.Contains(kv.Key))
                {
                    try
                    {
                        using (var alter = new SQLiteCommand($"ALTER TABLE Applicants ADD COLUMN {kv.Key} {kv.Value};", connection))
                            alter.ExecuteNonQuery();
                    }
                    catch { }
                }
            }

            // Проверяем и добавляем колонны в таблицу IndividualAchievements
            var individualAchievementsColumns = new Dictionary<string, string>
            {
                { "AchievementTypeId", "INTEGER" },
                { "Achievement", "TEXT" },
                { "AchievementName", "TEXT" },
                { "Year", "TEXT" },
                { "Points", "INTEGER DEFAULT 0" },
                { "DocumentName", "TEXT" },
                { "DocumentPath", "TEXT" }
            };

            var existingAchievements = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            try
            {
                using (var cmd = new SQLiteCommand("PRAGMA table_info(IndividualAchievements);", connection))
                using (var reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                        existingAchievements.Add(reader[1].ToString());
                }
            }
            catch { return; }

            foreach (var kv in individualAchievementsColumns)
            {
                if (!existingAchievements.Contains(kv.Key))
                {
                    try
                    {
                        using (var alter = new SQLiteCommand($"ALTER TABLE IndividualAchievements ADD COLUMN {kv.Key} {kv.Value};", connection))
                            alter.ExecuteNonQuery();
                    }
                    catch { }
                }
            }
        }

        public static string GetConnectionString()
        {
            string dbDirectory = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "App_Data");
            if (!Directory.Exists(dbDirectory)) Directory.CreateDirectory(dbDirectory);
            return $"Data Source={Path.Combine(dbDirectory, "AdmissionsReserve.db")};Version=3;Foreign Keys=True;";
        }

        public static string GetDatabasePath()
        {
            return Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "App_Data", "AdmissionsReserve.db");
        }

        public static SQLiteConnection GetConnection()
        {
            var connection = new SQLiteConnection(connectionString);
            connection.Open();
            using (var cmd = new SQLiteCommand("PRAGMA foreign_keys = ON;", connection))
                cmd.ExecuteNonQuery();
            return connection;
        }
