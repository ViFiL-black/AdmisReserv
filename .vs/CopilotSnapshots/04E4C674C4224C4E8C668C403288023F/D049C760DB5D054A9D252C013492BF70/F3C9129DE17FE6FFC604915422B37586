<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="Admissions_Reserve.View.AdditionalInfoPage"
    Title="Дополнительная информация">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="15">

                <!-- ========== ЗАГОЛОВОК ========== -->
                <TextBlock Text="Дополнительная информация" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <!-- ========== СНИЛС И ИНН ========== -->
                <TextBlock Text="СНИЛС и ИНН" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA" CornerRadius="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Страна рождения" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <ComboBox x:Name="BirthCountryCombo" Grid.Column="1" Height="23" FontSize="11"/>
                            </Grid>

                            <CheckBox x:Name="NoSnilsCheckBox" Content="У меня нет СНИЛС" FontSize="11" Margin="0,0,0,10" 
                                     Checked="NoSnilsCheckBox_Checked" Unchecked="NoSnilsCheckBox_Unchecked"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="СНИЛС" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBox x:Name="SnilsTextBox" Grid.Column="1" Height="23" FontSize="11" IsEnabled="True"
                                         LostFocus="SnilsTextBox_LostFocus" PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ИНН" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBox x:Name="InnTextBox" Grid.Column="1" Height="23" FontSize="11" MaxLength="12" ToolTip="12 цифр"
                                         LostFocus="InnTextBox_LostFocus" PreviewTextInput="InnTextBox_PreviewTextInput"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Формат СНИЛС:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton x:Name="SnilsSpaceRadio" Content="Пробел (XXX XXX XXX XX)" FontSize="10" Margin="0,0,15,0" IsChecked="True"/>
                                <RadioButton x:Name="SnilsHyphenRadio" Content="Дефис (XXX-XXX-XXX XX)" FontSize="10" Margin="0,0,15,0"/>
                                <RadioButton x:Name="SnilsNoneRadio" Content="Без разделителей" FontSize="10"/>
                            </StackPanel>
                            <TextBlock Text="Пример: 123 456 789 01 или 123-456-789 01" FontSize="9" Foreground="Gray"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ========== ОБЩЕЖИТИЕ ========== -->
                <TextBlock Text="Общежитие" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA" CornerRadius="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="NeedsDormitoryCheckBox" Content="Нуждается в общежитии" FontSize="11" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" x:Name="HasDormitoryBenefitsCheckBox" Content="Есть льготы для поселения в общежитие" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ========== ИНОСТРАННЫЕ ЯЗЫКИ ========== -->
                <TextBlock Text="Иностранные языки" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Добавление языка" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="LanguageCombo" Grid.Column="0" Height="23" FontSize="11" Margin="0,0,10,0"/>
                            <ComboBox x:Name="LanguageLevelCombo" Grid.Column="1" Height="23" FontSize="11" Margin="0,0,10,0"/>
                            <CheckBox x:Name="IsPrimaryLanguageCheckBox" Grid.Column="2" Content="Основной" FontSize="11" VerticalAlignment="Center"/>
                            <Button x:Name="AddLanguageButton" Grid.Column="3" Content="Добавить" Width="70" Height="25"
                                    FontSize="10" Background="#007ACC" Foreground="White" Click="AddLanguageButton_Click"/>
                        </Grid>

                        <TextBlock Text="Изучаемые языки:" FontSize="10" Foreground="Gray" Margin="0,5,0,5"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" MaxHeight="120">
                            <DataGrid x:Name="LanguagesGrid" AutoGenerateColumns="False"
                                      CanUserAddRows="False" HeadersVisibility="Column" FontSize="11" BorderThickness="1"
                                      BorderBrush="#CCCCCC">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Язык" Width="120" Binding="{Binding Language}" />
                                    <DataGridTextColumn Header="Степень владения" Width="200" Binding="{Binding Level}" />
                                    <DataGridCheckBoxColumn Header="Основной" Width="70" Binding="{Binding IsPrimary}" />
                                    <DataGridTemplateColumn Header="Удалить" Width="50">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✖" FontSize="10" Width="25" Height="20"
                                                        Background="#FF5722" Foreground="White"
                                                        Click="DeleteLanguage_Click" Tag="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- ========== СПОРТИВНЫЕ ДОСТИЖЕНИЯ ========== -->
                <TextBlock Text="Спортивные достижения" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <CheckBox x:Name="HasSportsAchievementsCheckBox" Content="Имеет спортивные достижения" FontSize="11" Margin="0,0,0,10"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA" CornerRadius="5"
                        IsEnabled="{Binding IsChecked, ElementName=HasSportsAchievementsCheckBox}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вид спорта" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBox x:Name="SportTypeTextBox" Grid.Column="1" Height="23" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Разряд/звание" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBox x:Name="SportRankTextBox" Grid.Column="3" Height="23" FontSize="11"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Год достижения" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBox x:Name="SportYearTextBox" Grid.Column="1" Height="23" FontSize="11" Margin="0,0,10,0" MaxLength="4" ToolTip="ГГГГ"/>
                            <Button x:Name="AddSportButton" Grid.Column="3" Content="➕ Добавить достижение" Width="140" Height="28"
                                    FontSize="10" Background="#4CAF50" Foreground="White" Click="AddSportButton_Click" HorizontalAlignment="Left"/>
                        </Grid>

                        <TextBlock Text="Список достижений:" FontSize="10" Foreground="Gray" Margin="0,5,0,5"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" MaxHeight="120">
                            <DataGrid x:Name="SportsGrid" AutoGenerateColumns="False"
                                      CanUserAddRows="False" HeadersVisibility="Column" FontSize="11" BorderThickness="1"
                                      BorderBrush="#CCCCCC">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Вид спорта" Width="150" Binding="{Binding SportType}" />
                                    <DataGridTextColumn Header="Разряд/звание" Width="150" Binding="{Binding Rank}" />
                                    <DataGridTextColumn Header="Год" Width="80" Binding="{Binding Year}" />
                                    <DataGridTemplateColumn Header="Удалить" Width="50">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✖" FontSize="10" Width="25" Height="20"
                                                        Background="#FF5722" Foreground="White"
                                                        Click="DeleteSport_Click" Tag="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- ========== ПРОФИЛЬНАЯ ПОДГОТОВКА ========== -->
                <TextBlock Text="Сведения о профильной подготовке" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA" CornerRadius="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="CompletedPreparatoryCoursesCheckBox" Content="Подготовительные курсы" FontSize="11" Margin="0,0,15,0"/>
                        <CheckBox Grid.Column="1" x:Name="CompletedPreparatoryDepartmentCheckBox" Content="Подготовительные отделения" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- ========== МЕДИЦИНСКОЕ ОБРАЗОВАНИЕ ========== -->
                <TextBlock Text="Медицинское образование" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA" CornerRadius="5">
                    <CheckBox x:Name="CompletedMedicalEducationCheckBox"
                              Content="Закончил медицинское (фармацевтическое) образовательное учреждение"
                              FontSize="11"/>
                </Border>

                <!-- ========== ТРУДОУСТРОЙСТВО ========== -->
                <TextBlock Text="Сведения о трудоустройстве" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA" CornerRadius="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Место работы" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBox x:Name="CurrentWorkPlaceTextBox" Grid.Column="1" Height="23" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- ========== СЛУЖБА В АРМИИ ========== -->
                <TextBlock Text="Сведения о службе в армии" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <CheckBox x:Name="ServedInArmyCheckBox" Content="Служил в армии" FontSize="11" Margin="0,0,0,10"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA" CornerRadius="5"
                        IsEnabled="{Binding IsChecked, ElementName=ServedInArmyCheckBox}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Дата начала службы" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <DatePicker x:Name="ServiceStartDatePicker" Grid.Column="1" Height="23" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Дата окончания службы" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <DatePicker x:Name="ServiceEndDatePicker" Grid.Column="3" Height="23" FontSize="11"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Год увольнения в запас" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBox x:Name="ReserveYearTextBox" Grid.Column="1" Height="23" FontSize="11" MaxLength="4" ToolTip="ГГГГ"
                                     LostFocus="ReserveYearTextBox_LostFocus" PreviewTextInput="ReserveYearTextBox_PreviewTextInput"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ========== КНОПКИ НАВИГАЦИИ ========== -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
                    <Button x:Name="PrevButton" Content="Назад" Click="PrevButton_Click" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#F0F0F0"/>
                    <Button x:Name="NextButton" Content="Далее" Click="NextButton_Click" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White"/>
                    <Button x:Name="CancelButton" Content="Отменить" Click="CancelButton_Click" Width="90" Height="32" FontSize="11" Background="#F0F0F0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>