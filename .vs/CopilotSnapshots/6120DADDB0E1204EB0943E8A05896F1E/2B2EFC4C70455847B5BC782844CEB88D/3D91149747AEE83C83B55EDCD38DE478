<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="Admissions_Reserve.View.AttachedDocumentsPage"
    Title="Приложенные документы">
	<DockPanel>
		<Grid>
			<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
				<StackPanel Margin="15">

					<!-- ========== ЗАГОЛОВОК ========== -->
					<TextBlock Text="Основные документы, приложенные к заявлению" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

					<!-- ========== ДОКУМЕНТ ОБ ОБРАЗОВАНИИ ========== -->
					<Border BorderBrush="#E8EFF7" BorderThickness="1" CornerRadius="5" Margin="0,0,0,15" Padding="12" Background="#E8EFF7">
						<StackPanel>
							<TextBlock Text="📄 Документ об образовании" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Тип документа:" FontSize="12"/>
								<TextBlock Grid.Column="1" Name="EduDocType" Text="Аттестат о среднем общем образовании" FontSize="12" FontWeight="SemiBold" Margin="0,0,10,0"/>
								<TextBlock Grid.Column="2" Text="Дата выдачи:" FontSize="12"/>
								<TextBlock Grid.Column="3" Name="EduDocDate" Text="01.01.2023" FontSize="12" FontWeight="SemiBold"/>
							</Grid>
							<Grid Margin="0,8,0,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Серия и номер:" FontSize="12"/>
								<TextBlock Grid.Column="1" Name="EduDocSeriesNumber" Text="78 01 123456" FontSize="12" Margin="0,0,10,0"/>
								<TextBlock Grid.Column="2" Text="Кем выдан:" FontSize="12"/>
								<TextBlock Grid.Column="3" Name="EduDocIssuedBy" Text="Департамент образования г. Москвы" FontSize="12"/>
							</Grid>
						</StackPanel>
					</Border>

					<!-- ========== УДОСТОВЕРЕНИЕ ЛИЧНОСТИ ========== -->
					<Border BorderBrush="#E8F4FD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,15" Padding="12" Background="#E8F4FD">
						<StackPanel>
							<TextBlock Text="🆔 Удостоверение личности" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Тип документа:" FontSize="12"/>
								<TextBlock Grid.Column="1" Name="IdDocType" Text="Паспорт гражданина РФ" FontSize="12" FontWeight="SemiBold" Margin="0,0,10,0"/>
								<TextBlock Grid.Column="2" Text="Дата выдачи:" FontSize="12"/>
								<TextBlock Grid.Column="3" Name="IdDocDate" Text="15.06.2015" FontSize="12" FontWeight="SemiBold"/>
							</Grid>
							<Grid Margin="0,8,0,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Серия и номер:" FontSize="12"/>
								<TextBlock Grid.Column="1" Name="IdDocSeriesNumber" Text="45 07 654321" FontSize="12" Margin="0,0,10,0"/>
								<TextBlock Grid.Column="2" Text="Кем выдан:" FontSize="12"/>
								<TextBlock Grid.Column="3" Name="IdDocIssuedBy" Text="Отделом УФМС России по г. Москве" FontSize="12"/>
							</Grid>
						</StackPanel>
					</Border>

					<!-- ========== ТАБЛИЦА ДОКУМЕНТОВ ========== -->
					<TextBlock Text="Прочие документы, приложенные к заявлению" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

					<Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15">
						<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="350">
							<DataGrid Name="DocumentsGrid" AutoGenerateColumns="False"
                                      CanUserAddRows="True" CanUserDeleteRows="True"
                                      HeadersVisibility="Column" FontSize="11" BorderThickness="0"
                                      RowHeaderWidth="0" HorizontalAlignment="Stretch">
								<DataGrid.Columns>
									<DataGridTextColumn Header="№" Width="40" Binding="{Binding Number}" />
									<DataGridTextColumn Header="Тип документа" Width="150" Binding="{Binding DocumentType}" />
									<DataGridTextColumn Header="Серия и номер" Width="120" Binding="{Binding SeriesNumber}" />
									<DataGridTextColumn Header="Категория" Width="120" Binding="{Binding Category}" />
									<DataGridTextColumn Header="Доп. данные" Width="120" Binding="{Binding AdditionalData}" />
									<DataGridTextColumn Header="Дата выдачи" Width="100" Binding="{Binding IssueDate, StringFormat='dd.MM.yyyy'}" />
									<DataGridTextColumn Header="Информация о документе" Width="200" Binding="{Binding DocumentInfo}" />
									<DataGridTextColumn Header="Дата добавления" Width="140" Binding="{Binding AddedDate, StringFormat='dd.MM.yyyy HH:mm'}" />
									<DataGridTemplateColumn Header="Приложение" Width="80">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<Button Content="Скачать" FontSize="10" Width="60" Height="22"
                                                        Click="DownloadAttachment_Click" Tag="{Binding}"
                                                        Background="#007ACC" Foreground="White"/>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
									<DataGridTemplateColumn Header="Удалить" Width="50">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<Button Content="X" FontSize="10" Width="25" Height="20"
                                                        Click="DeleteDocument_Click" Tag="{Binding}"
                                                        Background="#FF5722" Foreground="White"/>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
								</DataGrid.Columns>
							</DataGrid>
						</ScrollViewer>
					</Border>

					<!-- ========== ФОРМА ДОБАВЛЕНИЯ ДОКУМЕНТА ========== -->
					<Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="12" Margin="0,0,0,15" Background="#FAFAFA">
						<StackPanel>
							<TextBlock Text="Добавление документа" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

							<Grid Margin="0,0,0,10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="140"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="140"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Название документа*" FontSize="11" VerticalAlignment="Center"/>
								<ComboBox Grid.Column="1" Name="DocumentTypeCombo" Height="23" FontSize="11" Margin="0,0,10,0" IsEditable="True">
									<ComboBoxItem Content="Свидетельство о рождении"/>
									<ComboBoxItem Content="СНИЛС"/>
									<ComboBoxItem Content="ИНН"/>
									<ComboBoxItem Content="Медицинская справка"/>
									<ComboBoxItem Content="Справка об инвалидности"/>
									<ComboBoxItem Content="Свидетельство о браке"/>
									<ComboBoxItem Content="Военный билет"/>
									<ComboBoxItem Content="Фотография 3x4"/>
									<ComboBoxItem Content="Характеристика"/>
									<ComboBoxItem Content="Портфолио достижений"/>
								</ComboBox>
								<TextBlock Grid.Column="2" Text="Дата выдачи" FontSize="11" VerticalAlignment="Center"/>
								<DatePicker Grid.Column="3" Name="IssueDatePicker" Height="23" FontSize="11"/>
							</Grid>

							<Grid Margin="0,0,0,10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="140"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="140"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Серия и номер" FontSize="11" VerticalAlignment="Center"/>
								<TextBox Grid.Column="1" Name="SeriesNumberTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
								<TextBlock Grid.Column="2" Text="Категория" FontSize="11" VerticalAlignment="Center"/>
								<ComboBox Grid.Column="3" Name="CategoryCombo" Height="23" FontSize="11" SelectedIndex="0">
									<ComboBoxItem Content="Абитуриент"/>
									<ComboBoxItem Content="Родитель"/>
									<ComboBoxItem Content="Опекун"/>
									<ComboBoxItem Content="Супруг(а)"/>
								</ComboBox>
							</Grid>

							<Grid Margin="0,0,0,10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="140"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="140"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Дополнительные данные" FontSize="11" VerticalAlignment="Center"/>
								<TextBox Grid.Column="1" Name="AdditionalDataTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
								<TextBlock Grid.Column="2" Text="Информация о документе" FontSize="11" VerticalAlignment="Center"/>
								<TextBox Grid.Column="3" Name="DocumentInfoTextBox" Height="23" FontSize="11"/>
							</Grid>

							<Grid Margin="0,0,0,10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="140"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Файл приложения" FontSize="11" VerticalAlignment="Center"/>
								<StackPanel Grid.Column="1" Orientation="Horizontal">
									<TextBox Name="AttachmentFileNameTextBox" Height="23" FontSize="11" Width="300" Margin="0,0,10,0" IsReadOnly="True"/>
									<Button Name="UploadFileButton" Content="Выбрать файл" Width="100" Height="25"
                                            FontSize="10" Background="#4CAF50" Foreground="White" Click="UploadFileButton_Click"/>
								</StackPanel>
							</Grid>

							<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
								<Button Name="AddDocumentButton" Content="Заполнить работу с настройками" Width="200" Height="30"
                                        Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White" Click="AddDocumentButton_Click"/>
								<Button Name="CancelAddButton" Content="Отменить" Width="90" Height="30" FontSize="11"
                                        Background="#F0F0F0" Click="CancelAddButton_Click"/>
							</StackPanel>
						</StackPanel>
					</Border>

				</StackPanel>
			</ScrollViewer>
		</Grid>
		<local:NavigationBar x:Name="NavBar" DockPanel.Dock="Bottom" />
	</DockPanel>
</Page>