<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="Admissions_Reserve.View.IdentityPage"
      Title="Удостоверение личности">
	<Grid>
		<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<StackPanel Margin="15">
				<!-- Выбор удостоверения личности -->
				<TextBlock Text="Выбор удостоверения личности" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
				<StackPanel Margin="0,0,0,12">
					<RadioButton x:Name="ExistingIdentityRadio" Content="▼" Margin="0,0,0,5" FontSize="11"/>
					<RadioButton Content="Новое удостоверение личности" Margin="0,0,0,5" FontSize="11"/>
				</StackPanel>

				<!-- ФИО -->
				<TextBlock Text="ФИО" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
				<Grid Margin="0,0,0,12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" Margin="0,0,8,0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Фамилия " FontSize="11"/>
							<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
						</StackPanel>
						<TextBox Height="23" FontSize="11"/>
					</StackPanel>
					<StackPanel Grid.Column="1" Margin="0,0,8,0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Имя " FontSize="11"/>
							<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
						</StackPanel>
						<TextBox Height="23" FontSize="11"/>
					</StackPanel>
					<StackPanel Grid.Column="2">
						<TextBlock Text="Отчество" FontSize="11"/>
						<TextBox Height="23" FontSize="11"/>
					</StackPanel>
				</Grid>

				<!-- Удостоверение личности -->
				<TextBlock Text="Удостоверение личности" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
				<Grid Margin="0,0,0,8">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="140"/>
						<ColumnDefinition Width="90"/>
						<ColumnDefinition Width="100"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" Margin="0,0,8,0">
						<TextBlock Text="Тип удостоверения" FontSize="11"/>
						<ComboBox Height="23" FontSize="11">
							<ComboBoxItem Content="Паспорт"/>
							<ComboBoxItem Content="Свидетельство о рождении"/>
						</ComboBox>
					</StackPanel>
					<StackPanel Grid.Column="1" Margin="0,0,8,0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Серия " FontSize="11"/>
							<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
						</StackPanel>
						<TextBox Height="23" FontSize="11"/>
					</StackPanel>
					<StackPanel Grid.Column="2" Margin="0,0,8,0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Номер " FontSize="11"/>
							<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
						</StackPanel>
						<TextBox Height="23" FontSize="11"/>
					</StackPanel>
					<StackPanel Grid.Column="3">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Гражданство " FontSize="11"/>
							<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
						</StackPanel>
						<ComboBox Height="23" FontSize="11">
							<ComboBoxItem Content="Российская Федерация"/>
							<ComboBoxItem Content="Беларусь"/>
							<ComboBoxItem Content="Казахстан"/>
							<ComboBoxItem Content="Украина"/>
						</ComboBox>
					</StackPanel>
				</Grid>

				<Grid Margin="0,0,0,8">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="110"/>
						<ColumnDefinition Width="130"/>
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" Margin="0,0,8,0">
						<TextBlock Text="Кем выдано удостоверение" FontSize="11"/>
						<TextBox Height="23" FontSize="11"/>
					</StackPanel>
					<StackPanel Grid.Column="1" Margin="0,0,8,0">
						<TextBlock Text="Код подразделения" FontSize="11"/>
						<TextBox Height="23" FontSize="11"/>
					</StackPanel>
					<StackPanel Grid.Column="2">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Дата выдачи " FontSize="11"/>
							<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
						</StackPanel>
						<DatePicker Height="23" FontSize="11"/>
					</StackPanel>
				</Grid>

				
				<Grid Margin="0,0,0,12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" Margin="0,0,8,0">
						<TextBlock Text="Пол" FontSize="11"/>
						<ComboBox Height="23" FontSize="11">
							<ComboBoxItem Content="Мужской"/>
							<ComboBoxItem Content="Женский"/>
						</ComboBox>
					</StackPanel>
					<StackPanel Grid.Column="1" Margin="0,0,8,0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Дата рождения " FontSize="11"/>
							<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
						</StackPanel>
						<DatePicker Height="23" FontSize="11"/>
					</StackPanel>
					<StackPanel Grid.Column="2">
						<TextBlock Text="Место рождения" FontSize="11"/>
						<TextBox Height="23" FontSize="11"/>
					</StackPanel>
				</Grid>

				<!-- СНИЛС -->
				<TextBlock Text="СНИЛС" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
				<Grid Margin="0,0,0,0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="180"/>
						<ColumnDefinition Width="180"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" Margin="0,0,10,12">
						<TextBlock Text="СНИЛС (третий символ с конца) " FontSize="11"/>
						<RadioButton Content="Пробел" Margin="0,0,0,3" FontSize="11"/>
						<RadioButton Content="Дефис" Margin="0,0,0,3" FontSize="11"/>
					</StackPanel>
					<StackPanel Grid.Column="1" Margin="0,0,8,0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="СНИЛС" FontSize="11"/>
							<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
						</StackPanel>
						<TextBox Height="23" FontSize="11"/>
					</StackPanel>
					
				</Grid>

				

				<!-- Адрес регистрации -->
				<TextBlock Text="Адрес регистрации" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>
				<Grid Margin="0,0,0,8">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0">
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="Страна " FontSize="11"/>
							<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
						</StackPanel>
						<ComboBox Height="23" FontSize="11">
							<ComboBoxItem Content="Российская Федерация"/>
							<ComboBoxItem Content="Беларусь"/>
							<ComboBoxItem Content="Казахстан"/>
							<ComboBoxItem Content="Украина"/>
						</ComboBox>
					</StackPanel>
				</Grid>

				<StackPanel Margin="0,0,0,8">
					<TextBlock Text="Адрес ФИАС" FontSize="11"/>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox Grid.Column="0" Height="23" FontSize="11"/>
						<Button Grid.Column="1" Content="Проверить" Width="100" Height="23" Margin="5,0,0,0" FontSize="11"/>
					</Grid>
				</StackPanel>

				<StackPanel Margin="0,0,0,12">
					<TextBlock Text="Квартира" FontSize="11"/>
					<TextBox Height="23" FontSize="11"/>
				</StackPanel>

				<CheckBox Content="Адрес регистрации совпадает с фактическим адресом" Margin="0,0,0,15" FontSize="11"/>

				<!-- Кнопки навигации -->
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
					<Button x:Name="PrevButton" Content="Назад" Width="90" Height="32" Margin="0,0,10,0" FontSize="11"/>
					<Button x:Name="NextButton" Content="Далее" Width="90" Height="32" Margin="0,0,10,0" FontSize="11"/>
					<Button x:Name="CancelButton" Content="Отменить" Width="90" Height="32" FontSize="11"/>
				</StackPanel>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</Page>