<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="Admissions_Reserve.View.IndividualAchievementsPage"
    Title="Индивидуальные достижения">

	<Grid>
		<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<StackPanel Margin="15">

				<!-- ========== ЗАГОЛОВОК ========== -->
				<TextBlock Text="Индивидуальные достижения" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

				<!-- ========== ОПИСАНИЕ ========== -->
				<TextBlock Text="Укажите индивидуальные достижения, которые дают преимущество при поступлении"
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,15"/>

				<!-- ========== ФОРМА ДОБАВЛЕНИЯ ДОСТИЖЕНИЯ ========== -->
				<Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="12" Margin="0,0,0,15" Background="#FAFAFA">
					<StackPanel>
						<TextBlock Text="Добавление достижения" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="140"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="140"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Категория достижения*" FontSize="11" VerticalAlignment="Center"/>
							<ComboBox Grid.Column="1" Name="CategoryCombo" Height="23" FontSize="11" Margin="0,0,10,0"
                                      SelectionChanged="CategoryCombo_SelectionChanged">
								<ComboBoxItem Content="Победитель всероссийской олимпиады школьников"/>
								<ComboBoxItem Content="Призер всероссийской олимпиады школьников"/>
								<ComboBoxItem Content="Победитель олимпиады школьников из перечня Минобрнауки"/>
								<ComboBoxItem Content="Призер олимпиады школьников из перечня Минобрнауки"/>
								<ComboBoxItem Content="Значок ГТО (золотой)"/>
								<ComboBoxItem Content="Значок ГТО (серебряный)"/>
								<ComboBoxItem Content="Аттестат с отличием (золотая медаль)"/>
								<ComboBoxItem Content="Аттестат с отличием (серебряная медаль)"/>
								<ComboBoxItem Content="Диплом СПО с отличием"/>
								<ComboBoxItem Content="Волонтерская деятельность"/>
								<ComboBoxItem Content="Участие в творческих конкурсах"/>
								<ComboBoxItem Content="Спортивные достижения"/>
								<ComboBoxItem Content="Наличие статуса победителя чемпионата «Профессионалы»"/>
								<ComboBoxItem Content="Наличие статуса призера чемпионата «Профессионалы»"/>
								<ComboBoxItem Content="Наличие статуса победителя чемпионата «Абилимпикс»"/>
								<ComboBoxItem Content="Наличие статуса призера чемпионата «Абилимпикс»"/>
								<ComboBoxItem Content="Иное"/>
							</ComboBox>
							<TextBlock Grid.Column="2" Text="Количество баллов" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="3" Name="PointsTextBox" Height="23" FontSize="11" Text="0" TextAlignment="Right"/>
						</Grid>

						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="140"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="140"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Наименование достижения" FontSize="11" VerticalAlignment="Center"/>
							<TextBox Grid.Column="1" Name="AchievementNameTextBox" Height="23" FontSize="11" Margin="0,0,10,0"/>
							<TextBlock Grid.Column="2" Text="Год достижения" FontSize="11" VerticalAlignment="Center"/>
							<ComboBox Grid.Column="3" Name="YearCombo" Height="23" FontSize="11" SelectedIndex="0">
								<ComboBoxItem Content="2026"/>
								<ComboBoxItem Content="2025"/>
								<ComboBoxItem Content="2024"/>
								<ComboBoxItem Content="2023"/>
								<ComboBoxItem Content="2022"/>
								<ComboBoxItem Content="2021"/>
								<ComboBoxItem Content="2020"/>
								<ComboBoxItem Content="2019"/>
								<ComboBoxItem Content="2018"/>
							</ComboBox>
						</Grid>

						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="140"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Документ, подтверждающий достижение" FontSize="11" VerticalAlignment="Center"/>
							<StackPanel Grid.Column="1" Orientation="Horizontal">
								<TextBox Name="DocumentInfoTextBox" Height="23" FontSize="11" Width="300" Margin="0,0,10,0"/>
								<Button Name="UploadFileButton" Content="Загрузить файл" Width="100" Height="25"
                                        FontSize="10" Background="#4CAF50" Foreground="White" Click="UploadFileButton_Click"/>
							</StackPanel>
						</Grid>

						<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
							<Button Name="AddAchievementButton" Content="Добавить достижение" Width="150" Height="30"
                                    Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White" Click="AddAchievementButton_Click"/>
							<Button Name="CancelAddButton" Content="Отменить" Width="90" Height="30" FontSize="11"
                                    Background="#F0F0F0" Click="CancelAddButton_Click"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- ========== ТАБЛИЦА ИНДИВИДУАЛЬНЫХ ДОСТИЖЕНИЙ ========== -->
				<TextBlock Text="Список индивидуальных достижений" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

				<Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15">
					<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="300">
						<DataGrid Name="AchievementsGrid" AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="True"
                                  HeadersVisibility="Column" FontSize="11" BorderThickness="0"
                                  RowHeaderWidth="0">
							<DataGrid.Columns>
								<DataGridTextColumn Header="№" Width="40" Binding="{Binding Number}" />
								<DataGridTextColumn Header="Категория достижения" Width="280" Binding="{Binding Category}" />
								<DataGridTextColumn Header="Наименование" Width="200" Binding="{Binding AchievementName}" />
								<DataGridTextColumn Header="Год" Width="60" Binding="{Binding Year}" />
								<DataGridTextColumn Header="Баллы" Width="60" Binding="{Binding Points}" />
								<DataGridTextColumn Header="Подтверждающий документ" Width="200" Binding="{Binding DocumentName}" />
								<DataGridTemplateColumn Header="Удалить" Width="50">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<Button Content="X" FontSize="10" Width="25" Height="20"
                                                    Click="DeleteAchievement_Click" Tag="{Binding}"/>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
							</DataGrid.Columns>
						</DataGrid>
					</ScrollViewer>
				</Border>

				<!-- ========== СУММА БАЛЛОВ ========== -->
				<Border BorderBrush="#007ACC" BorderThickness="2" CornerRadius="5" Margin="0,0,0,15" Padding="10" Background="#E8F4FD">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Общая сумма баллов за индивидуальные достижения:"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
						<Border Grid.Column="1" Background="#007ACC" CornerRadius="5" Padding="15,8">
							<TextBlock Name="TotalPointsTextBlock" Text="0" FontSize="18" FontWeight="Bold" Foreground="White"/>
						</Border>
					</Grid>
				</Border>

				<!-- ========== ИНФОРМАЦИЯ О МАКСИМАЛЬНЫХ БАЛЛАХ ========== -->
				<Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FFF9E6">
					<StackPanel>
						<TextBlock Text="Информация о начислении баллов" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
						<TextBlock Text="• Победители и призеры олимпиад - до 10 баллов" FontSize="10" Foreground="Gray"/>
						<TextBlock Text="• Значок ГТО - 2-5 баллов (в зависимости от вуза)" FontSize="10" Foreground="Gray"/>
						<TextBlock Text="• Аттестат/диплом с отличием - 5-10 баллов" FontSize="10" Foreground="Gray"/>
						<TextBlock Text="• Волонтерская деятельность - 1-3 балла" FontSize="10" Foreground="Gray"/>
						<TextBlock Text="• Максимальная сумма за все достижения - 20 баллов" FontSize="10" Foreground="Gray" FontWeight="SemiBold"/>
					</StackPanel>
				</Border>

				<!-- ========== КНОПКИ НАВИГАЦИИ ========== -->
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
					<Button x:Name="PrevButton" Content="Назад" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#F0F0F0"/>
					<Button x:Name="NextButton" Content="Далее" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White"/>
					<Button x:Name="CancelButton" Content="Отменить" Width="90" Height="32" FontSize="11" Background="#F0F0F0"/>
				</StackPanel>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</Page>