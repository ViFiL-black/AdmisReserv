<Page x:Class="Admissions_Reserve.View.ApplicantSearchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Admissions_Reserve"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Поиск абитуриентов">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20">
                <!-- Заголовок -->
                <TextBlock Text="Поиск абитуриентов по ФИО" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <!-- Форма поиска -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="15" Margin="0,0,0,20" Background="#FAFAFA" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Введите данные для поиска" FontSize="13" FontWeight="Bold" Margin="0,0,0,15"/>

                        <!-- Строка 1: Фамилия, Имя, Отчество -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Фамилия" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Name="LastNameSearchBox" Height="25" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Имя" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="3" Name="FirstNameSearchBox" Height="25" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="4" Text="Отчество" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="5" Name="PatronymicSearchBox" Height="25" FontSize="11"/>
                        </Grid>

                        <!-- Строка 2: Кнопки поиска и очистки -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Name="SearchButton" Content="🔍 Поиск" Width="100" Height="30" FontSize="11"
                                    Background="#007ACC" Foreground="White" Click="SearchButton_Click" Margin="0,0,10,0"/>
                            <Button Name="ClearSearchButton" Content="Очистить" Width="100" Height="30" FontSize="11"
                                    Background="#F0F0F0" Click="ClearSearchButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Результаты поиска -->
                <TextBlock Text="Результаты поиска" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <!-- Таблица результатов -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,20" CornerRadius="5">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                        <DataGrid Name="SearchResultsGrid" AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  HeadersVisibility="Column" FontSize="11" BorderThickness="0"
                                  RowHeaderWidth="0" MouseDoubleClick="SearchResultsGrid_DoubleClick"
                                  SelectionChanged="SearchResultsGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Фамилия" Width="120" Binding="{Binding LastName}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Имя" Width="100" Binding="{Binding FirstName}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Отчество" Width="100" Binding="{Binding Patronymic}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Дата рождения" Width="110" Binding="{Binding BirthDate, StringFormat='dd.MM.yyyy'}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Email" Width="150" Binding="{Binding Email}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Телефон" Width="120" Binding="{Binding Phone}" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Действия" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Открыть" FontSize="10" Width="60" Height="22" Margin="2"
                                                        Background="#2196F3" Foreground="White" ToolTip="Открыть профиль"
                                                        Click="OpenButton_Click" Tag="{Binding}"/>
                                                <Button Content="Изм." FontSize="10" Width="45" Height="22" Margin="2"
                                                        Background="#FF9800" Foreground="White" ToolTip="Изменить"
                                                        Click="EditButton_Click" Tag="{Binding}"/>
                                                <Button Content="Удал." FontSize="10" Width="45" Height="22" Margin="2"
                                                        Background="#F44336" Foreground="White" ToolTip="Удалить"
                                                        Click="DeleteButton_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>

                <!-- Информация о результатах -->
                <TextBlock Name="SearchStatusText" Text="Введите ФИО для поиска" FontSize="11" Foreground="#666666" Margin="0,10,0,0"/>

                <!-- Кнопки навигации -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
                    <Button Name="BackButton" Content="Назад" Width="100" Height="32" FontSize="11" Background="#F0F0F0" Click="BackButton_Click"/>
                    <Button Name="NewApplicantButton" Content="+ Новый абитуриент" Width="150" Height="32" FontSize="11" 
                            Background="#4CAF50" Foreground="White" Margin="10,0,0,0" Click="NewApplicantButton_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
