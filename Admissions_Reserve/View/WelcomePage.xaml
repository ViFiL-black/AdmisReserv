<Page x:Class="Admissions_Reserve.WelcomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Admissions_Reserve"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WelcomePage">

    <Grid>
    <TextBlock Text="Добро пожаловать" FontSize="28" FontWeight="Bold" Margin="30,30,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
    <TextBlock Text="Резервное приложение для приемной комиссии" FontSize="16" Margin="32,80,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <Button x:Name="BtnSearch" Content="Войти" Width="150" Height="40" Margin="30,150,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Click="BtnSearch_Click" Background="#007ACC" Foreground="White" FontSize="12" FontWeight="Bold"/>
    <Button x:Name="BtnExit" Content="Выход" Width="150" Height="40" Margin="200,150,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Click="BtnExit_Click"/>
</Grid>
</Page>
