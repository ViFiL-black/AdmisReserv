<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="Admissions_Reserve.View.AttachedDocumentsPage"
    Title="Приложенные документы">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="15">

                <TextBlock Text="Основные документы, приложенные к заявлению" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <!-- Документ об образовании -->
                <Border BorderBrush="#E8EFF7" BorderThickness="1" CornerRadius="5" Margin="0,0,0,15" Padding="12" Background="#E8EFF7">
                    <StackPanel>
                        <TextBlock Text="📄 Документ об образовании" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Тип документа:" FontSize="12"/>
                            <TextBlock Grid.Column="1" x:Name="EduDocType" Text="-" FontSize="12" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Дата выдачи:" FontSize="12"/>
                            <TextBlock Grid.Column="3" x:Name="EduDocDate" Text="-" FontSize="12" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Серия и номер:" FontSize="12"/>
                            <TextBlock Grid.Column="1" x:Name="EduDocSeriesNumber" Text="-" FontSize="12" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Организация:" FontSize="12"/>
                            <TextBlock Grid.Column="3" x:Name="EduDocOrg" Text="-" FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Удостоверение личности -->
                <Border BorderBrush="#E8F4FD" BorderThickness="1" CornerRadius="5" Margin="0,0,0,15" Padding="12" Background="#E8F4FD">
                    <StackPanel>
                        <TextBlock Text="🆔 Удостоверение личности" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Тип документа:" FontSize="12"/>
                            <TextBlock Grid.Column="1" x:Name="IdDocType" Text="-" FontSize="12" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Дата выдачи:" FontSize="12"/>
                            <TextBlock Grid.Column="3" x:Name="IdDocDate" Text="-" FontSize="12" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Серия и номер:" FontSize="12"/>
                            <TextBlock Grid.Column="1" x:Name="IdDocSeriesNumber" Text="-" FontSize="12" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Кем выдан:" FontSize="12"/>
                            <TextBlock Grid.Column="3" x:Name="IdDocIssuedBy" Text="-" FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Таблица прочих документов -->
                <TextBlock Text="Прочие документы, приложенные к заявлению" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="250">
                        <DataGrid x:Name="DocumentsGrid" AutoGenerateColumns="False"
                                  CanUserAddRows="False" HeadersVisibility="Column" FontSize="11" BorderThickness="0"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№" Width="40" Binding="{Binding Number}" />
                                <DataGridTextColumn Header="Тип документа" Width="150" Binding="{Binding DocumentType}" />
                                <DataGridTextColumn Header="Серия и номер" Width="120" Binding="{Binding SeriesNumber}" />
                                <DataGridTextColumn Header="Категория" Width="120" Binding="{Binding Category}" />
                                <DataGridTextColumn Header="Дата выдачи" Width="100" Binding="{Binding IssueDate, StringFormat='dd.MM.yyyy'}" />
                                <DataGridTextColumn Header="Информация" Width="200" Binding="{Binding DocumentInfo}" />
                                <DataGridTemplateColumn Header="Удалить" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✖" FontSize="10" Width="25" Height="20"
                                                    Background="#FF5722" Foreground="White"
                                                    Click="DeleteDocument_Click" Tag="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>


                <!-- Кнопки -->
                <!-- Кнопки навигации - замените на это -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
                    <Button x:Name="PrevButton" Content="Назад" Click="PrevButton_Click" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#F0F0F0"/>
                    <Button x:Name="CompleteButton" Content="Завершить" Click="CompleteButton_Click" Width="120" Height="32" Margin="0,0,10,0" FontSize="11" Background="#4CAF50" Foreground="White"/>
                    <Button x:Name="CancelButton" Content="Отменить" Click="CancelButton_Click" Width="90" Height="32" FontSize="11" Background="#F0F0F0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>