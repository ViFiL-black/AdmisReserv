<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    mc:Ignorable="d" 
    x:Class="Admissions_Reserve.View.PrioritiesPage"
    Title="Приоритеты зачисления">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="15">

                <!-- ========== ЗАГОЛОВОК ========== -->
                <TextBlock Text="Приоритеты зачисления" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>

                <TextBlock Text="Установите приоритет зачисления по конкурсным группам" 
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,15"/>

                <!-- ========== ИНФОРМАЦИЯ О НАБОРЕ ========== -->
                <Border BorderBrush="#E8EFF7" BorderThickness="1" CornerRadius="5" Margin="0,0,0,15" Padding="10" Background="#E8EFF7">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Этап набора:" FontSize="12" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <TextBlock Name="StageText" Text="Основной набор" FontSize="12" Foreground="#007ACC"/>
                    </StackPanel>
                </Border>

                <!-- ========== ТАБЛИЦА ПРИОРИТЕТОВ ========== -->
                <TextBlock Text="Приоритеты" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <DataGrid Name="PrioritiesGrid" AutoGenerateColumns="False" 
                  CanUserAddRows="False" CanUserDeleteRows="False" 
                  CanUserReorderColumns="False" CanUserResizeRows="False"
                  HeadersVisibility="Column" FontSize="12" BorderThickness="0"
                  RowHeaderWidth="0" RowHeight="50" 
                  AllowDrop="True" HorizontalAlignment="Stretch">

                            <DataGrid.Columns>
                                <!-- Приоритет - фиксированная ширина 70 -->
                                <DataGridTextColumn Header="Приоритет" Width="70" Binding="{Binding Priority}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Рукоятка для перетаскивания - фиксированная ширина 40 -->
                                <DataGridTemplateColumn Header="" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent" Cursor="SizeAll" ToolTip="Перетащите для изменения приоритета">
                                                <TextBlock Text="⋮⋮" FontSize="16" FontWeight="Bold" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Выбор - фиксированная ширина 50 -->
                                <DataGridTemplateColumn Header="Выбор" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      ToolTip="Выберите для зачисления"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Название конкурса - занимает всё оставшееся пространство (Width="*") -->
                                <DataGridTextColumn Header="Название" Width="600" Binding="{Binding DisplayName}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="5"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Переместить - фиксированная ширина 80 -->
                                <DataGridTemplateColumn Header="Переместить" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="▲" Width="25" Height="25" Margin="2" FontSize="12"
                                        ToolTip="Повысить приоритет"
                                        Click="MoveUp_Click" Tag="{Binding}"/>
                                                <Button Content="▼" Width="25" Height="25" Margin="2" FontSize="12"
                                        ToolTip="Понизить приоритет"
                                        Click="MoveDown_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>
                <!-- ========== ИНСТРУКЦИЯ ========== -->
                <Border BorderBrush="#FFF9E6" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FFF9E6">
                    <StackPanel>
                        <TextBlock Text="Инструкция по установке приоритетов" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="• Чем выше приоритет (меньший номер), тем больше шансов на зачисление" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="• Перетащите строку за значок ⋮⋮ для изменения приоритета" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="• Используйте кнопки ▲▼ для изменения приоритета" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="• Отметьте галочкой конкурсы, по которым хотите участвовать" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="• Зачисление производится по наивысшему приоритету" FontSize="10" Foreground="Gray" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- ========== КНОПКИ НАВИГАЦИИ ========== -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
                    <Button x:Name="PrevButton" Content="Назад" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#F0F0F0"/>
                    <Button x:Name="NextButton" Content="Далее" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White"/>
                    <Button x:Name="CancelButton" Content="Отменить" Width="90" Height="32" FontSize="11" Background="#F0F0F0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>