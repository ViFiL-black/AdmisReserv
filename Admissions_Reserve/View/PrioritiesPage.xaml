<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    mc:Ignorable="d" 
    x:Class="Admissions_Reserve.View.PrioritiesPage"
    Title="Приоритеты зачисления">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="15">

                <!-- ========== ЗАГОЛОВОК ========== -->
                <TextBlock Text="Приоритеты зачисления" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>

                <TextBlock Text="Установите приоритет зачисления по конкурсным группам" 
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,15"/>

                <!-- ========== ТАБЛИЦА ПРИОРИТЕТОВ ========== -->
                <TextBlock Text="Приоритеты" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <DataGrid Name="PrioritiesGrid" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" CanUserDeleteRows="False" 
                                  CanUserReorderColumns="False" CanUserResizeRows="False"
                                  HeadersVisibility="Column" FontSize="12" BorderThickness="0"
                                  RowHeaderWidth="0" RowHeight="50">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Приоритет" Width="70" Binding="{Binding Priority}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridCheckBoxColumn Header="Выбор" Width="50" Binding="{Binding IsSelected}">
                                    <DataGridCheckBoxColumn.ElementStyle>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridCheckBoxColumn.ElementStyle>
                                </DataGridCheckBoxColumn>

                                <DataGridTextColumn Header="Название" Width="*" Binding="{Binding DisplayName}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="5"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Переместить" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="▲" Width="25" Height="25" Margin="2" FontSize="12"
                                                        ToolTip="Повысить приоритет"
                                                        Click="MoveUp_Click" Tag="{Binding}"/>
                                                <Button Content="▼" Width="25" Height="25" Margin="2" FontSize="12"
                                                        ToolTip="Понизить приоритет"
                                                        Click="MoveDown_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>

                <!-- ========== ИНСТРУКЦИЯ ========== -->
                <Border BorderBrush="#FFF9E6" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FFF9E6">
                    <StackPanel>
                        <TextBlock Text="Инструкция" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="• Чем выше приоритет (меньше номер), тем больше шансов на зачисление" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="• Используйте кнопки ▲▼ для изменения приоритета" FontSize="10" Foreground="Gray"/>
                        <TextBlock Text="• Отметьте галочкой конкурсы для участия" FontSize="10" Foreground="Gray"/>
                    </StackPanel>
                </Border>

                <!-- ========== КНОПКИ ========== -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
                    <Button x:Name="PrevButton" Content="Назад" Click="PrevButton_Click" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#F0F0F0"/>
                    <Button x:Name="NextButton" Content="Далее" Click="NextButton_Click" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White"/>
                    <Button x:Name="CancelButton" Content="Отменить" Click="CancelButton_Click" Width="90" Height="32" FontSize="11" Background="#F0F0F0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>