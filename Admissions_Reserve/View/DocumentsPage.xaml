<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    mc:Ignorable="d" 
    x:Class="Admissions_Reserve.View.DocumentsPage"
    Title="Документы">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="15">

                <!-- ========== ЗАГОЛОВОК ========== -->
                <TextBlock Text="Документы абитуриента" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <!-- ========== ФОРМА ДОБАВЛЕНИЯ ДОКУМЕНТА ========== -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="12" Margin="0,0,0,15" Background="#FAFAFA" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Добавление документа" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                        <!-- Первая строка: Вид документа -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вид документа:" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="IdentityDocRadio" Content="Документ, удостоверяющий личность" 
                                             Margin="0,0,15,0" FontSize="11" IsChecked="True" Checked="IdentityDocRadio_Checked"/>
                                <RadioButton x:Name="OtherDocRadio" Content="Другой документ персональных данных" 
                                             FontSize="11" Checked="OtherDocRadio_Checked"/>
                            </StackPanel>
                        </Grid>

                        <!-- Вторая строка: Данные документа -->
                        <TextBlock Text="Данные документа" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Тип документа" FontSize="11"/>
                                <TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold" Margin="2,0,0,0"/>
                            </StackPanel>
                            <!-- ComboBox с данными из БД -->
                            <ComboBox x:Name="DocumentTypeCombo" Grid.Column="1" Height="23" FontSize="11" Margin="0,0,10,0" 
                                      DisplayMemberPath="Name" SelectedValuePath="Id" IsEditable="False"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Категория" FontSize="11"/>
                                <TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold" Margin="2,0,0,0"/>
                            </StackPanel>
                            <ComboBox x:Name="CategoryCombo" Grid.Column="3" Height="23" FontSize="11" SelectedIndex="0">
                                <ComboBoxItem Content="Абитуриент (прием 2026)"/>
                                <ComboBoxItem Content="Родитель"/>
                                <ComboBoxItem Content="Опекун"/>
                                <ComboBoxItem Content="Супруг(а)"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Серия" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox x:Name="SeriesTextBox" Grid.Column="1" Height="23" FontSize="11" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Номер" FontSize="11"/>
                                <TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold" Margin="2,0,0,0"/>
                            </StackPanel>
                            <TextBox x:Name="NumberTextBox" Grid.Column="3" Height="23" FontSize="11"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Дата выдачи" FontSize="11" VerticalAlignment="Center"/>
                            <DatePicker x:Name="IssueDatePicker" Grid.Column="1" Height="23" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Кем выдан" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox x:Name="IssuedByTextBox" Grid.Column="3" Height="23" FontSize="11"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Доп. данные" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox x:Name="AdditionalDataTextBox" Grid.Column="1" Height="23" FontSize="11" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="Информация о документе" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox x:Name="DocumentInfoTextBox" Grid.Column="3" Height="23" FontSize="11"/>
                        </Grid>

                        <!-- Загрузка файла -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Приложение (файл)" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox x:Name="AttachmentFileTextBox" Grid.Column="1" Height="23" FontSize="11" IsReadOnly="True" Background="#F5F5F5" Margin="0,0,8,0"/>
                            <Button x:Name="UploadFileButton" Grid.Column="2" Content="Выбрать файл" Width="100" Height="23" 
                                    FontSize="10" Background="#4CAF50" Foreground="White" Click="UploadFileButton_Click"/>
                        </Grid>

                        <!-- Кнопки формы -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button x:Name="AddToListButton" Content="Добавить в список документов" Width="200" Height="30" 
                                    Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White" Click="AddDocumentButton_Click"/>
                            <Button x:Name="CancelAddButton" Content="Отменить" Width="90" Height="30" FontSize="11" 
                                    Background="#F0F0F0" Click="CancelAddButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ========== ТАБЛИЦА ДОКУМЕНТОВ ========== -->
                <TextBlock Text="Список документов" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" CornerRadius="5">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="250">
                        <DataGrid x:Name="DocumentsGrid" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" CanUserDeleteRows="True" 
                                  HeadersVisibility="Column" FontSize="11" BorderThickness="0"
                                  RowHeaderWidth="0" IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№" Width="40" Binding="{Binding Number}" />
                                <DataGridTextColumn Header="Тип документа" Width="160" Binding="{Binding DocumentType}" />
                                <DataGridTextColumn Header="Серия и номер" Width="130" Binding="{Binding SeriesNumber}" />
                                <DataGridTextColumn Header="Категория" Width="140" Binding="{Binding Category}" />
                                <DataGridTextColumn Header="Доп. данные" Width="120" Binding="{Binding AdditionalData}" />
                                <DataGridTextColumn Header="Дата выдачи" Width="100" Binding="{Binding IssueDate, StringFormat='dd.MM.yyyy'}" />
                                <DataGridTextColumn Header="Информация о документе" Width="200" Binding="{Binding DocumentInfo}" />
                                <DataGridTextColumn Header="Дата добавления" Width="140" Binding="{Binding AddedDate, StringFormat='dd.MM.yyyy HH:mm'}" />
                                <DataGridTextColumn Header="Категория ПД" Width="160" Binding="{Binding PersonalDataCategory}" />
                                <DataGridTemplateColumn Header="Файл" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="📎" FontSize="12" Width="25" Height="22" 
                                                    ToolTip="Открыть файл" Click="OpenFile_Click" Tag="{Binding}"
                                                    Visibility="{Binding HasAttachment}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Удалить" Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✖" FontSize="10" Width="25" Height="20" 
                                                    Background="#FF5722" Foreground="White"
                                                    Click="DeleteDocument_Click" Tag="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>

                <!-- ========== ДОКУМЕНТЫ ПЕРСОНАЛЬНЫХ ДАННЫХ ========== -->
                <TextBlock Text="Документы персональных данных" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" CornerRadius="5">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                        <DataGrid x:Name="PersonalDataDocumentsGrid" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" CanUserDeleteRows="False" 
                                  HeadersVisibility="Column" FontSize="11" BorderThickness="0"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№" Width="40" Binding="{Binding Number}" />
                                <DataGridTextColumn Header="Тип документа" Width="160" Binding="{Binding DocumentType}" />
                                <DataGridTextColumn Header="Серия и номер" Width="130" Binding="{Binding SeriesNumber}" />
                                <DataGridTextColumn Header="Категория" Width="140" Binding="{Binding Category}" />
                                <DataGridTextColumn Header="Доп. данные" Width="120" Binding="{Binding AdditionalData}" />
                                <DataGridTextColumn Header="Дата выдачи" Width="100" Binding="{Binding IssueDate, StringFormat='dd.MM.yyyy'}" />
                                <DataGridTextColumn Header="Информация о документе" Width="250" Binding="{Binding DocumentInfo}" />
                                <DataGridTextColumn Header="Дата добавления" Width="140" Binding="{Binding AddedDate, StringFormat='dd.MM.yyyy HH:mm'}" />
                                <DataGridTextColumn Header="Категория ПД" Width="160" Binding="{Binding PersonalDataCategory}" />
                                <DataGridTemplateColumn Header="Файл" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="📎" FontSize="12" Width="25" Height="22" 
                                                    ToolTip="Открыть файл" Click="OpenFile_Click" Tag="{Binding}"
                                                    Visibility="{Binding HasAttachment}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>

                <!-- ========== КНОПКИ НАВИГАЦИИ ========== -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
                    <Button x:Name="PrevButton" Content="Назад" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#F0F0F0" Click="PrevButton_Click"/>
                    <Button x:Name="NextButton" Content="Далее" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White" Click="NextButton_Click"/>
                    <Button x:Name="SaveButton" Content="Сохранить" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#4CAF50" Foreground="White" Click="SaveButton_Click"/>
                    <Button x:Name="CancelButton" Content="Отменить" Width="90" Height="32" FontSize="11" Background="#F0F0F0" Click="CancelButton_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page> 