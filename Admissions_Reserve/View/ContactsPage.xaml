<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="Admissions_Reserve.View.ContactsPage"
    Title="Контакты">

	<Grid>
		<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<StackPanel Margin="15">

				<!-- ========== ЗАГОЛОВОК ========== -->
				<TextBlock Text="Контактная информация" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

				<!-- ========== КОНТАКТНЫЕ ДАННЫЕ ========== -->
				<TextBlock Text="Контактные данные" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

				<Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<!-- Левая колонка -->
						<StackPanel Grid.Column="0" Margin="0,0,15,0">
							<Grid Margin="0,0,0,10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Контактный телефон" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
								<TextBox x:Name="ContactPhoneTextBox" Height="23" FontSize="11" Grid.Column="1" ToolTip="+7 (XXX) XXX-XX-XX"/>
							</Grid>

							<Grid Margin="0,0,0,10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Мобильный телефон" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
								<TextBox x:Name="MobilePhoneTextBox" Height="23" FontSize="11" Grid.Column="1" ToolTip="+7 (XXX) XXX-XX-XX"/>
							</Grid>

							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Факс" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
								<TextBox x:Name="FaxTextBox" Height="23" FontSize="11" Grid.Column="1"/>
							</Grid>
						</StackPanel>

						<!-- Правая колонка -->
						<StackPanel Grid.Column="1">
							<Grid Margin="0,0,0,10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Рабочий телефон" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
								<TextBox x:Name="WorkPhoneTextBox" Height="23" FontSize="11" Grid.Column="1"/>
							</Grid>

							<Grid Margin="0,0,0,10">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="120"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
									<TextBlock Text="E-mail" FontSize="11" FontWeight="SemiBold"/>
									<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold" Margin="2,0,0,0"/>
								</StackPanel>
								<TextBox x:Name="EmailTextBox" Height="23" FontSize="11" Grid.Column="1" ToolTip="example@mail.ru"/>
							</Grid>

							<Grid Margin="0,0,0,10">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <TextBlock Grid.Column="0" Text="Доп E-mail" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
    <TextBox x:Name="AdditionalEmailTextBox" Height="23" FontSize="11" Grid.Column="1"/>
</Grid>
						</StackPanel>
					</Grid>
				</Border>

				<!-- ========== АДРЕС ПРОЖИВАНИЯ ========== -->
				<TextBlock Text="Адрес проживания (фактический)" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

				<Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA">
					<StackPanel>
						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<StackPanel Grid.Column="0" Margin="0,0,8,0">
								<StackPanel Orientation="Horizontal">
									<TextBlock Text="Страна" FontSize="11" FontWeight="SemiBold"/>
									<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
								</StackPanel>
								<ComboBox x:Name="CountryCombo" Height="23" FontSize="11" SelectedIndex="0"/>
							</StackPanel>
							<StackPanel Grid.Column="1" Margin="0,0,8,0">
								<TextBlock Text="Индекс" FontSize="11" FontWeight="SemiBold"/>
								<TextBox x:Name="PostalCodeTextBox" Height="23" FontSize="11" MaxLength="6"/>
							</StackPanel>
							<StackPanel Grid.Column="2">
								<TextBlock Text="Регион/Область" FontSize="11" FontWeight="SemiBold"/>
								<TextBox x:Name="RegionTextBox" Height="23" FontSize="11"/>
							</StackPanel>
						</Grid>

						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<StackPanel Grid.Column="0" Margin="0,0,8,0">
								<TextBlock Text="Район" FontSize="11" FontWeight="SemiBold"/>
								<TextBox x:Name="DistrictTextBox" Height="23" FontSize="11"/>
							</StackPanel>
							<StackPanel Grid.Column="1" Margin="0,0,8,0">
								<StackPanel Orientation="Horizontal">
									<TextBlock Text="Населенный пункт" FontSize="11" FontWeight="SemiBold"/>
									<TextBlock Text="*" Foreground="Red" FontSize="11" FontWeight="Bold"/>
								</StackPanel>
								<TextBox x:Name="CityTextBox" Height="23" FontSize="11"/>
							</StackPanel>
							<StackPanel Grid.Column="2">
								<TextBlock Text="Улица" FontSize="11" FontWeight="SemiBold"/>
								<TextBox x:Name="StreetTextBox" Height="23" FontSize="11"/>
							</StackPanel>
						</Grid>

						<Grid Margin="0,0,0,10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<StackPanel Grid.Column="0" Margin="0,0,8,0">
								<TextBlock Text="Дом" FontSize="11" FontWeight="SemiBold"/>
								<TextBox x:Name="HouseTextBox" Height="23" FontSize="11"/>
							</StackPanel>
							<StackPanel Grid.Column="1" Margin="0,0,8,0">
								<TextBlock Text="Корпус/Строение" FontSize="11" FontWeight="SemiBold"/>
								<TextBox x:Name="BuildingTextBox" Height="23" FontSize="11"/>
							</StackPanel>
							<StackPanel Grid.Column="2" Margin="0,0,8,0">
								<TextBlock Text="Квартира/Офис" FontSize="11" FontWeight="SemiBold"/>
								<TextBox x:Name="ApartmentTextBox" Height="23" FontSize="11"/>
							</StackPanel>
							<Button Grid.Column="3" x:Name="CheckAddressButton" Content="Проверить" Width="90" Height="23"
                                    FontSize="10" Background="#007ACC" Foreground="White" Margin="8,20,0,0"/>
						</Grid>

						<CheckBox x:Name="CopyFromRegistrationCheckBox" Content="Скопировать адрес из данных удостоверения личности"
                                  Margin="0,15,0,0" FontSize="11" Checked="CopyFromRegistration_Checked"/>
					</StackPanel>
				</Border>

				<!-- ========== ДОПОЛНИТЕЛЬНАЯ ИНФОРМАЦИЯ ========== -->
				<TextBlock Text="Дополнительная информация" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

				<Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0" Margin="0,0,15,0">
							<TextBlock Text="Сайт/Портфолио" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
							<TextBox x:Name="WebsiteTextBox" Height="23" FontSize="11" ToolTip="https://..."/>

							<TextBlock Text="Telegram" FontSize="11" FontWeight="SemiBold" Margin="0,15,0,5"/>
							<TextBox x:Name="TelegramTextBox" Height="23" FontSize="11" ToolTip="@username"/>
						</StackPanel>

						<StackPanel Grid.Column="1">
							<TextBlock Text="WhatsApp" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
							<TextBox x:Name="WhatsAppTextBox" Height="23" FontSize="11" ToolTip="+7 (XXX) XXX-XX-XX"/>

							<TextBlock Text="Viber" FontSize="11" FontWeight="SemiBold" Margin="0,15,0,5"/>
							<TextBox x:Name="ViberTextBox" Height="23" FontSize="11" ToolTip="+7 (XXX) XXX-XX-XX"/>
						</StackPanel>
					</Grid>
				</Border>

				<!-- ========== ПРЕДПОЧТИТЕЛЬНЫЙ СПОСОБ СВЯЗИ ========== -->
				<TextBlock Text="Предпочтительный способ связи" FontSize="13" FontWeight="Bold" Background="#E8EFF7" Padding="8" Margin="0,0,0,8"/>

				<Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA">
					<StackPanel>
						<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
							<RadioButton x:Name="PreferredPhoneRadio" GroupName="PreferredContact" Content="Телефон"
                                         Margin="0,0,20,0" FontSize="11" IsChecked="True"/>
							<RadioButton x:Name="PreferredEmailRadio" GroupName="PreferredContact" Content="E-mail"
                                         Margin="0,0,20,0" FontSize="11"/>
							<RadioButton x:Name="PreferredMessengerRadio" GroupName="PreferredContact" Content="Мессенджер (Telegram/WhatsApp)"
                                         FontSize="11"/>
						</StackPanel>

						<TextBlock Text="Комментарий к контактной информации" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
						<TextBox x:Name="CommentTextBox" Height="50" FontSize="11" TextWrapping="Wrap"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 ToolTip="Дополнительная информация для связи"/>
					</StackPanel>
				</Border>

				<!-- ========== КНОПКИ НАВИГАЦИИ ========== -->
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
                    <Button x:Name="PrevButton" Content="Назад" Click="PrevButton_Click" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#F0F0F0"/>
                    <Button x:Name="NextButton" Content="Далее" Click="NextButton_Click" Width="90" Height="32" Margin="0,0,10,0" FontSize="11" Background="#007ACC" Foreground="White"/>
                    <Button x:Name="CancelButton" Content="Отменить" Click="CancelButton_Click" Width="90" Height="32" FontSize="11" Background="#F0F0F0"/>
                </StackPanel>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</Page>